local entObjects = {}

-- Smoothed velocity tracking using exponential moving average
-- Single-frame velocity is too noisy â€” EMA smooths it out
local _prevPos    = {}
local _prevTime   = {}
local _smoothVel  = {}  -- smoothed velocity per bone
local VEL_ALPHA   = 0.4  -- EMA weight: higher = more responsive, lower = smoother

local function getBoneVel(bone)
    local now = tick()
    local cur = bone.Position
    local prev = _prevPos[bone]
    local pt   = _prevTime[bone]
    _prevPos[bone]  = cur
    _prevTime[bone] = now

    if not prev or not pt then
        _smoothVel[bone] = Vector3.new(0,0,0)
        return _smoothVel[bone]
    end
    local dt = now - pt
    if dt <= 0 or dt > 0.3 then
        _smoothVel[bone] = Vector3.new(0,0,0)
        return _smoothVel[bone]
    end

    -- Raw velocity this frame
    local rawVel = (cur - prev) / dt

    -- Exponential moving average
    local prev_smooth = _smoothVel[bone] or Vector3.new(0,0,0)
    _smoothVel[bone] = prev_smooth + (rawVel - prev_smooth) * VEL_ALPHA

    return _smoothVel[bone]
end

local function getNearestTarget()
    Camera = workspace.CurrentCamera or Camera
    if not Camera then return nil end
    local char=LocalPlayer and LocalPlayer.Character
    if not char then return nil end
    local vp=Camera.ViewportSize
    local cx,cy=vp.X*0.5,vp.Y*0.5
    local fovSq=AIM.fov*AIM.fov
    local best,bestDSq=nil,huge
    local function checkChar(charModel,isPlayer)
        if AIM.targetMode=="npc" and isPlayer then return end
        if AIM.targetMode=="players" and not isPlayer then return end
        local bone=charModel:FindFirstChild(AIM.bone) or charModel:FindFirstChild("HumanoidRootPart")
        if not bone then return end
        local hum=charModel:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health<=0 then return end
        local sc,on=WorldToScreen(bone.Position)
        if not on then return end
        local dx=sc.X-cx; local dy=sc.Y-cy; local dSq=dx*dx+dy*dy
        if dSq<fovSq and dSq<bestDSq then bestDSq=dSq; best=bone end
    end
    for _,e in ipairs(entObjects) do
        if e.char and e.char.Parent then checkChar(e.char,e.isPlayer) end
    end
    return best
end

local function doAimbot()
    Camera = workspace.CurrentCamera or Camera
    if not Camera then
        fovCircle.Visible=false
        return
    end
    if AIM.showFOV and AIM.enabled then
        local vp=Camera.ViewportSize
        fovCircle.Position=Vector2.new(vp.X*0.5,vp.Y*0.5)
        fovCircle.Radius=AIM.fov; fovCircle.Visible=true
    else fovCircle.Visible=false end

    local keyDown=false
    if AIM.enabled then
        if AIM.keyType=="mouse1" then keyDown=ismouse1pressed()
        elseif AIM.keyType=="mouse2" then keyDown=ismouse2pressed()
        elseif AIM.keyType=="key" and AIM.keyCode then
            local ok,v=pcall(iskeypressed,AIM.keyCode); keyDown=ok and v or false
        end
    end

    if not keyDown then return end
    local target=getNearestTarget()
    if not target then return end
    local vel      = getBoneVel(target)
    local predPos  = target.Position + vel * AIM.predTime
    local sc,on=WorldToScreen(predPos)
    if not on then return end
    local vp=Camera.ViewportSize
    local dx=sc.X-(vp.X*0.5); local dy=sc.Y-(vp.Y*0.5)
    if abs(dx)<1 and abs(dy)<1 then return end
    local smooth=AIM.smooth
    local mx=floor(dx*smooth); local my=floor(dy*smooth)
    if mx==0 and abs(dx)>=1 then mx=dx>0 and 1 or -1 end
    if my==0 and abs(dy)>=1 then my=dy>0 and 1 or -1 end
    mousemoverel(mx,my)
end

