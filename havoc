local function hazardDisplayColor(default)
    if CFG.hazardColor~="Type Colors" then return selectedColor(CFG.hazardColor) end
    return default
end
local function getSliderTier(name)
    local n=name:match("[Ll]evel[-% ]?(%d)") or name:match("(%d)")
    if n then local t=tonumber(n); if t and t>=0 and t<=6 then return t end end
end
local function rebuildHazards()
    local lp=Players.LocalPlayer; local char=lp and lp.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then hazObjects={}; return end
    local myPos=hrp.Position
    local out={}
    local function scanFolder(folder,fn)
        if not folder then return end
        local ok,kids=pcall(function() return folder:GetChildren() end)
        if not ok or not kids then return end
        for _,obj in ipairs(kids) do fn(obj) end
    end
    if CFG.sentryEnabled then
        local sf=resolveFolder("sentry",function() return workspace.Buildings.EventObjects.Sentries end)
        local sentryDSq=HAZARD_DIST.sentry*HAZARD_DIST.sentry
        scanFolder(sf,function(obj)
            local a=obj:FindFirstChild("Base") or obj:FindFirstChild("Rotator") or obj:FindFirstChildWhichIsA("BasePart")
            if a and a.Parent then
                local rp=a.Position
                local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                if dx*dx+dy*dy+dz*dz<=sentryDSq then
                    out[#out+1]={part=a,label="[SENTRY] "..obj.Name,color=hazardDisplayColor(HAZARD_COLORS.sentry)}
                end
            end
        end)
    end
    if CFG.corpseEnabled then
        local cf=resolveFolder("corpse",function() return workspace.Buildings.Loots.Loots:FindFirstChild("Characters") end)
        local corpseDSq=HAZARD_DIST.corpse*HAZARD_DIST.corpse
        scanFolder(cf,function(m)
            if m.ClassName=="Model" then
                local a=m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Torso") or m:FindFirstChild("Head") or m:FindFirstChildWhichIsA("BasePart")
                if a and a.Parent then
                    local rp=a.Position
                    local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                    if dx*dx+dy*dy+dz*dz<=corpseDSq then
                        out[#out+1]={part=a,label="[CORPSE] "..m.Name,color=hazardDisplayColor(HAZARD_COLORS.corpse)}
                    end
                end
            end
        end)
    end
    if CFG.sliderEnabled then
        local slF=resolveFolder("slider",function() return workspace.Buildings.Loots.Interactable:FindFirstChild("KeycardSliders") end)
        local sliderDSq=HAZARD_DIST.slider*HAZARD_DIST.slider
        scanFolder(slF,function(obj)
            if obj.ClassName=="Model" then
                local a=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if a and a.Parent then
                    local rp=a.Position
                    local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                    if dx*dx+dy*dy+dz*dz<=sliderDSq then
                        local tier=getSliderTier(obj.Name)
                        local color=(tier and HAZARD_COLORS.sliderColors[tier]) or HAZARD_COLORS.sliderFallback
                        out[#out+1]={part=a,label=(tier and "[SLIDER T"..tier.."]" or "[SLIDER]"),color=hazardDisplayColor(color)}
                    end
                end
            end
        end)
    end
    hazObjects=out
end

-- ============================================================
--  Event-driven cache refresh
-- ============================================================
-- World changes mark a cache as dirty. A short debounce collapses a large
-- spawn/despawn batch into one rebuild instead of constantly rescanning.
local refreshAt={entity=0,loot=0,hazard=0}
local lastRefresh={entity=0,loot=0,hazard=0}
local function markDirty(kind)
    refreshAt[kind]=tick()
end

HavocESP:Connect(workspace.DescendantAdded,function(obj)
    if obj:IsA("Model") or obj:IsA("Humanoid") then markDirty("entity") end
    if obj:IsA("BasePart") then
        markDirty("loot")
        markDirty("hazard")
    end
end)
HavocESP:Connect(workspace.DescendantRemoving,function(obj)
    if obj:IsA("Model") or obj:IsA("Humanoid") then markDirty("entity") end
    if obj:IsA("BasePart") then
        markDirty("loot")
        markDirty("hazard")
    end
end)
HavocESP:Connect(Players.PlayerAdded,function(player)
    markDirty("entity")
    HavocESP:Connect(player.CharacterAdded,function() markDirty("entity") end)
    HavocESP:Connect(player.CharacterRemoving,function() markDirty("entity") end)
end)
HavocESP:Connect(Players.PlayerRemoving,function() markDirty("entity") end)

task.spawn(function()
    while HavocESP.alive do
        local now=tick()
        -- The timed checks are only fallbacks for games that recycle instances
        -- without emitting a useful child event.
        if CFG.entityEnabled and ((refreshAt.entity>0 and now-refreshAt.entity>=0.15) or now-lastRefresh.entity>=1) then
            pcall(rebuildEntities)
            refreshAt.entity=0; lastRefresh.entity=now
        end
        if CFG.lootEnabled and ((refreshAt.loot>0 and now-refreshAt.loot>=0.20) or now-lastRefresh.loot>=1.5) then
            pcall(rebuildLoot)
            refreshAt.loot=0; lastRefresh.loot=now
        end
        if (CFG.sentryEnabled or CFG.corpseEnabled or CFG.sliderEnabled) and ((refreshAt.hazard>0 and now-refreshAt.hazard>=0.25) or now-lastRefresh.hazard>=3) then
            pcall(rebuildHazards)
            refreshAt.hazard=0; lastRefresh.hazard=now
        end
        task.wait(0.1)
    end
end)

