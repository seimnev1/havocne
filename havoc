-- Havoc ESP v3: lifecycle and performance hardening
if _G.HavocESP then
    _G.HavocESP:Destroy()
end

local HavocESP = { alive = true, connections = {}, drawings = {} }
function HavocESP:Connect(signal, callback)
    local ok, connection = pcall(function()
        return signal:Connect(callback)
    end)
    if ok and connection then
        self.connections[#self.connections + 1] = connection
    end
    return connection
end
function HavocESP:TrackDrawing(drawing)
    self.drawings[#self.drawings + 1] = drawing
    return drawing
end
function HavocESP:Destroy()
    self.alive = false
    for _, connection in ipairs(self.connections) do
        pcall(function() connection:Disconnect() end)
    end
    for _, drawing in ipairs(self.drawings) do
        pcall(function() drawing:Remove() end)
    end
    self.connections = {}
    self.drawings = {}
end
_G.HavocESP = HavocESP
