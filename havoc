local function rebuildLoot()
    local lp=Players.LocalPlayer; local char=lp and lp.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then lootObjects={}; return end
    local myPos=hrp.Position; local maxDSq=CFG.maxDist*CFG.maxDist
    local lf=getLootsFolder(); if not lf then lootObjects={}; return end
    local itemsF=lf:FindFirstChild("Items")
    local loots2=lf:FindFirstChild("Loots")
    local cratesF=loots2 and loots2:FindFirstChild("Crates")
    local out={}
    local function scan(folder,colorFn,filterFn)
        if not folder then return end
        local ok,kids=pcall(function() return folder:GetChildren() end)
        if not ok or not kids then return end
        for _,obj in ipairs(kids) do
            if filterFn(obj.Name) then
                local root=obj:FindFirstChildWhichIsA("BasePart")
                if root and root.Parent then
                    local rp=root.Position
                    local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                    if dx*dx+dy*dy+dz*dz<=maxDSq then
                        out[#out+1]={part=root,name=obj.Name,color=colorFn(obj.Name)}
                    end
                end
            end
        end
    end
    scan(itemsF,function(n) return lootDisplayColor(itemColor(n)) end,function(n) return CFG.selectedItems[n]==true end)
    if CFG.showCrates and cratesF then
        local ok,kids=pcall(function() return cratesF:GetChildren() end)
        if ok and kids then
            for _,obj in ipairs(kids) do
                if CFG.selectedCrates[obj.Name] then
                    local root=obj:FindFirstChildWhichIsA("BasePart")
                    if root and root.Parent then
                        local rp=root.Position
                        local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                        if dx*dx+dy*dy+dz*dz<=maxDSq then
                            -- Read luck value directly from crate data
                            local data=obj:FindFirstChild("data")
                            local luckVal=data and data:FindFirstChild("luck")
                            out[#out+1]={
                                part=root,
                                name=obj.Name,
                                color=lootDisplayColor(crateColors[obj.Name] or Color3.fromRGB(200,200,200)),
                                luckRef=luckVal,
                            }
                        end
                    end
                end
            end
        end
    end
    lootObjects=out
end

