local V3_UP=Vector3.new(0,2.8,0)
local V3_DN=Vector3.new(0,-3.2,0)

local function hpColor(r)
    r=clamp(r,0,1)
    return Color3.fromRGB(floor(255*(1-r)),floor(220*r),40)
end

local recoilLast = 0

HavocESP:Connect(RunService.RenderStepped, function(dt)
    Camera = workspace.CurrentCamera or Camera
    if not Camera then return end
    if RECOIL.enabled and RECOIL.cache and tick() - recoilLast >= 0.1 then
        recoilLast = tick()
        pcall(applygc, RECOIL.cache, RECOIL.payload)
    end

    local lp=Players.LocalPlayer
    local char=lp and lp.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    local myPos=hrp and hrp.Position

    if CFG.showStatus then
        local fps=dt>0 and floor(1/dt+0.5) or 0
        statusText.Text="HAVOC v4  |  "..fps.." FPS  |  "..#entObjects.." entities  |  "..#lootObjects.." loot  |  "..#hazObjects.." hazards"
        statusText.Position=Vector2.new(12,12)
        statusText.Visible=true
    else
        statusText.Visible=false
    end

    -- â”€â”€ Loot â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local drawn=0
    if CFG.lootEnabled and myPos then
        for _,e in ipairs(lootObjects) do
            if e then
                local part=e.part
                if part and part.Parent then
                    local sc,on=WorldToScreen(part.Position)
                    if on then
                        if drawn < LOOT_POOL then
                            drawn=drawn+1
                            local rp=part.Position
                            local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                            local dist=floor(sqrt(dx*dx+dy*dy+dz*dz))
                            local lbl=lootLabels[drawn]; local dot=lootDots[drawn]
                            local txt
                            if e.luckRef and e.luckRef.Parent then
                                txt=e.name.." [luck:"..floor(e.luckRef.Value).."] ["..dist.."m]"
                            else
                                txt=e.name.." ["..dist.."m]"
                            end
                            lbl.Text=txt; lbl.Color=e.color
                            lbl.Position=Vector2.new(sc.X,sc.Y-10); lbl.Visible=true
                            dot.Color=e.color; dot.Position=Vector2.new(sc.X,sc.Y+6); dot.Visible=true
                        end
                    end
                end
            end
        end
    end
    for i=drawn+1,lootDrawn do lootLabels[i].Visible=false; lootDots[i].Visible=false end
    lootDrawn=drawn

    -- â”€â”€ Entity â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local eDrawn=0

    if CFG.entityEnabled and myPos then
        for _,e in ipairs(entObjects) do
            if e then
                local ph=e.hrp
                if ph and ph.Parent then
                    local headSc,headOn=WorldToScreen(ph.Position+V3_UP)
                    if headOn then
                        local footSc,footOn=WorldToScreen(ph.Position+V3_DN)
                        eDrawn=eDrawn+1
                        if eDrawn>ENT_MAX then break end
                        local s=entSlots[eDrawn]
                        local hum=e.hum
                        local hp=hum and hum.Health or 0
                        local maxhp=hum and hum.MaxHealth or 100
                        local hRatio=maxhp>0 and clamp(hp/maxhp,0,1) or 0
                        local hCol=hpColor(hRatio)
                        local rp2=ph.Position
                        local dx2=rp2.X-myPos.X; local dy2=rp2.Y-myPos.Y; local dz2=rp2.Z-myPos.Z
                        local dist=floor(sqrt(dx2*dx2+dy2*dy2+dz2*dz2))
                        local col=e.color
                        local hx=headSc.X; local hy=headSc.Y
                        local boxH=footOn and math.max(math.abs(footSc.Y-hy),10) or 60
                        local boxW=boxH*0.50
                        local boxLeft=hx-boxW*0.5
                        local boxColor=isBoss(e.label) and selectedColor(CFG.bossColor) or col
                        drawCornerBox(s,boxLeft,hy,boxW,boxH,boxColor,CFG.showCornerBox and footOn)
                        drawSkeleton(s,e.char,selectedColor(CFG.skeletonColor),CFG.showSkeleton and dist<=CFG.skeletonMaxDist)

                        if CFG.showName then
                            local prefix, nameCol
                            if e.isPlayer then
                                prefix="[P] "; nameCol=col
                            elseif isBoss(e.label) then
                                prefix="[BOSS] "; nameCol=selectedColor(CFG.bossColor)
                            else
                                prefix="[NPC] "; nameCol=col
                            end
                            s.name.Text=prefix..e.label
                            s.name.Color=nameCol
                            s.name.Position=Vector2.new(hx,hy-30)
                            s.name.Visible=true
                        else s.name.Visible=false end

                        if CFG.showDist then
                            s.dist.Text="["..dist.."m]"
                            s.dist.Color=Color3.fromRGB(210,210,210)
                            s.dist.Position=Vector2.new(hx,hy-14)
                            s.dist.Visible=true
                        else s.dist.Visible=false end

                        if CFG.showHealth and footOn then
                            local barX=boxLeft-7
                            s.hpBg.From=Vector2.new(barX,hy); s.hpBg.To=Vector2.new(barX,hy+boxH); s.hpBg.Visible=true
                            local fillBot=hy+boxH*(1-hRatio)
                            s.hpFg.Color=hCol; s.hpFg.From=Vector2.new(barX,hy+boxH); s.hpFg.To=Vector2.new(barX,fillBot); s.hpFg.Visible=true
                            s.hpTxt.Text=floor(hp).." HP"; s.hpTxt.Color=hCol
                            s.hpTxt.Position=Vector2.new(hx,hy+boxH+5); s.hpTxt.Visible=true
                        else s.hpBg.Visible=false; s.hpFg.Visible=false; s.hpTxt.Visible=false end

                        if CFG.showWeapon and footOn then
                            local tool=e.char and e.char:FindFirstChildOfClass("Tool")
                            local wname=tool and tool.Name
                            if wname then
                                if #wname>24 then wname=wname:sub(1,21).."..." end
                                s.weapon.Text="< "..wname.." >"; s.weapon.Color=Color3.fromRGB(255,220,100)
                                s.weapon.Position=Vector2.new(hx,hy+boxH+18); s.weapon.Visible=true
                            else s.weapon.Visible=false end
                        else s.weapon.Visible=false end
                    end
                end
            end
        end
    end
    for i=eDrawn+1,entDrawn do hideEnt(entSlots[i]) end
    entDrawn=eDrawn

    -- â”€â”€ Hazard â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local hDrawn=0
    if myPos then
        for _,e in ipairs(hazObjects) do
            if e then
                local part=e.part
                if part and part.Parent then
                    local sc,on=WorldToScreen(part.Position)
                    if on then
                        if hDrawn < HAZ_POOL then
                            hDrawn=hDrawn+1
                            local rp=part.Position
                            local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                            local dist=floor(sqrt(dx*dx+dy*dy+dz*dz))
                            local lbl=hazLabels[hDrawn]; local dot=hazDots[hDrawn]
                            lbl.Text=e.label.." ["..dist.."m]"; lbl.Color=e.color
                            lbl.Position=Vector2.new(sc.X,sc.Y-10); lbl.Visible=true
                            dot.Color=e.color; dot.Position=Vector2.new(sc.X,sc.Y+6); dot.Visible=true
                        end
                    end
                end
            end
        end
    end
    for i=hDrawn+1,hazDrawn do hazLabels[i].Visible=false; hazDots[i].Visible=false end
    hazDrawn=hDrawn

    -- â”€â”€ Inventory â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if CFG.invEnabled and myPos then
        -- Only show inventory while hold key is pressed
        local keyHeld = invHoldHandle:IsActivated()

        if not keyHeld then
            hideInvPanel()
            invCurrentEntity = nil
        else
        local vp=Camera.ViewportSize
        local cx,cy=vp.X*0.5,vp.Y*0.5
        local hrSq=CFG.invHoverRadius*CFG.invHoverRadius
        local found=nil
        if #entObjects==0 then pcall(rebuildEntities) end
        for _,e in ipairs(entObjects) do
            if e and e.hrp and e.hrp.Parent then
                local sc,on=WorldToScreen(e.hrp.Position+V3_UP)
                if on then
                    local dx=sc.X-cx; local dy=sc.Y-cy
                    if dx*dx+dy*dy<=hrSq then found=e; break end
                end
            end
        end
        if found then
            invRebuildTimer=invRebuildTimer+(1/60)
            if found~=invCurrentEntity or invRebuildTimer>=1 then
                invCurrentEntity=found; invRebuildTimer=0
                for i=1,invLinesDrawn do invLines[i].Visible=false end
                invLinesDrawn=0; invCurrentLines={}
                local label
                if found.isPlayer then
                    label="[PLAYER] "..found.label
                elseif isBoss(found.label) then
                    label="[BOSS] "..found.label
                else
                    label="[NPC] "..found.label
                end
                if found.char and found.char.Parent then
                    -- For NPCs try __tempSTORAGE backpack first (faster + more accurate)
                    if not found.isPlayer then
                        local bpLines = pcall and (function()
                            local ok, lines = pcall(getNPCBackpackLines, found.char)
                            return ok and lines or nil
                        end)()
                        if bpLines and #bpLines > 0 then
                            invCurrentLines = {
                                {text=label, color=Color3.fromRGB(255,80,80)},
                                {text="[Backpack Preview]", color=Color3.fromRGB(255,200,60)},
                            }
                            for _, l in ipairs(bpLines) do
                                invCurrentLines[#invCurrentLines+1] = l
                            end
                        else
                            -- Fallback to normal inventory scan
                            local ok,secs=pcall(collectInventory,found.char,found.plr,found.label)
                            if ok and secs then
                                invCurrentLines=buildLines(label,secs)
                            else
                                invCurrentLines={
                                    {text=label,color=Color3.fromRGB(255,80,80)},
                                    {text="  (no backpack data)",color=Color3.fromRGB(120,120,120)}
                                }
                            end
                        end
                    else
                        -- Players use normal inventory scan
                        local ok,secs=pcall(collectInventory,found.char,found.plr,found.label)
                        if ok and secs then
                            invCurrentLines=buildLines(label,secs)
                        else
                            invCurrentLines={
                                {text=label,color=Color3.fromRGB(80,220,255)},
                                {text="  (read error)",color=Color3.fromRGB(180,60,60)}
                            }
                        end
                    end
                end
            end
            local lineCount=math.min(#invCurrentLines,INV_LINES)
            local panelW=220; local panelH=lineCount*14+10
            invBg.Size=Vector2.new(panelW,panelH)
            invBg.Position=Vector2.new(CFG.invPanelX,CFG.invPanelY)
            invBg.Visible=true
            for i=1,lineCount do
                local line=invCurrentLines[i]; local obj=invLines[i]
                obj.Text=line.text; obj.Color=line.color
                obj.Position=Vector2.new(CFG.invPanelX+6,CFG.invPanelY+5+(i-1)*14)
                obj.Visible=true
            end
            for i=lineCount+1,invLinesDrawn do invLines[i].Visible=false end
            invLinesDrawn=lineCount
        else
            invCurrentEntity=nil; hideInvPanel()
        end
        end -- end keyHeld
    else
        hideInvPanel()
    end
end)

