local function getNPCBackpackLines(charModel)
    local storage = RS:FindFirstChild("__tempSTORAGE")
    if not storage then return nil end
    local backpacks = storage:FindFirstChild("npc_backpacks")
    if not backpacks then return nil end

    -- Find backpack matching this NPC's character model
    -- NPC backpacks link via an ObjectValue called "owner" or by checking items
    -- Try to match by finding a backpack whose parent model name matches
    local charName = charModel.Name

    -- Each backpack is named like "5df128_Backpack"
    -- We need to find which one belongs to this NPC
    -- Check if charModel has a backpack link
    local bpLink = charModel:FindFirstChild("backpackFolder")
        or charModel:FindFirstChild("backpack")
        or charModel:FindFirstChild("Backpack")

    local targetBp = nil

    if bpLink and bpLink:IsA("ObjectValue") then
        targetBp = bpLink.Value
    else
        -- Scan backpacks for one that references this character
        local ok, bps = pcall(function() return backpacks:GetChildren() end)
        if ok and bps then
            for _, bp in ipairs(bps) do
                local owner = bp:FindFirstChild("owner") or bp:FindFirstChild("Owner")
                if owner and owner:IsA("ObjectValue") and owner.Value == charModel then
                    targetBp = bp; break
                end
                -- Also try matching by name stored in bp
                local nameVal = bp:FindFirstChild("name") or bp:FindFirstChild("characterName")
                if nameVal and nameVal.Value == charName then
                    targetBp = bp; break
                end
            end
        end
    end

    if not targetBp then return nil end

    -- Read items from the backpack
    local itemsFolder = targetBp:FindFirstChild("items")
    if not itemsFolder then return nil end

    local lines = {}
    local ok, kids = pcall(function() return itemsFolder:GetChildren() end)
    if not ok or not kids then return nil end

    -- Count duplicates
    local itemCounts = {}
    for _, item in ipairs(kids) do
        local n = item.Name
        itemCounts[n] = (itemCounts[n] or 0) + 1
    end

    -- Build unique list
    local seen = {}
    for _, item in ipairs(kids) do
        local n = item.Name
        if not seen[n] then
            seen[n] = true
            local count = itemCounts[n]
            local label = count > 1 and (n .. " x"..count) or n
            lines[#lines+1] = { text="  |- "..label, color=getItemColor(n) }
        end
    end

    return lines
end

local function collectInventory(charModel,plrRef,plrName)
    local sections={}
    local plr=plrRef
    if not plr then
        local charName=plrName or ""
        pcall(function() if charName=="" then charName=charModel.Name end end)
        for _,p in ipairs(Players:GetPlayers()) do
            local pName=""
            pcall(function() pName=p.Name end)
            if pName:lower()==charName:lower() then plr=p; break end
            local ok,pchar=pcall(function() return p.Character end)
            if ok and pchar==charModel then plr=p; break end
        end
    end
    local bp=nil
    pcall(function() if plr then bp=plr:FindFirstChildOfClass("Backpack") end end)
    local SLOT_LABELS={backpack="Bag",helmet="Helmet",armor="Armor",
        lower_armor="Lower Armor",gloves="Gloves",face_cover="Face Cover"}
    if bp then
        local eq=nil
        pcall(function()
            for _,c in ipairs(bp:GetChildren()) do
                if c.Name:lower()=="equipment" then eq=c; break end
            end
        end)
        if eq then
            local gearItems={}
            pcall(function()
                for _,child in ipairs(eq:GetChildren()) do
                    local slotKey=child.Name:lower()
                    local label=SLOT_LABELS[slotKey] or cap(slotKey)
                    local folder=nil
                    pcall(function() folder=child.Value end)
                    if folder then
                        local itemName=""
                        pcall(function() itemName=folder.Name end)
                        if itemName~="" and itemName:lower()~="unreadable_name" then
                            local display=cap(itemName)
                            local extra=""
                            pcall(function()
                                local df=folder:FindFirstChild("data")
                                if df then
                                    local dur=df:FindFirstChild("durability")
                                    local maxDur=df:FindFirstChild("maxDurability")
                                    if dur and maxDur and maxDur.Value>0 then
                                        extra=" ("..floor((dur.Value/maxDur.Value)*100).."%)"
                                    end
                                end
                            end)
                            gearItems[#gearItems+1]={name=label..": "..display..extra,isGear=true}
                        end
                    end
                end
            end)
            if #gearItems>0 then
                sections[#sections+1]={header="[Equipment]",items=gearItems}
            end
        end
        local carriedItems={}
        local seenWeapons={}
        for _,obj in ipairs(charModel:GetChildren()) do
            if obj.ClassName=="Tool" then
                local n=""
                pcall(function() n=obj.Name end)
                if n~="" then seenWeapons[n]=true end
                break
            end
        end
        pcall(function()
            for _,obj in ipairs(bp:GetChildren()) do
                if obj.ClassName=="Tool" then
                    local n=""
                    pcall(function() n=obj.Name end)
                    if n~="" and n:lower()~="fists" and not seenWeapons[n] then
                        if isWeapon(obj) then
                            seenWeapons[n]=true
                            sections[#sections+1]={header="[Secondary] "..n,items=getWeaponData(obj)}
                        else
                            carriedItems[#carriedItems+1]={name=n}
                        end
                    end
                end
            end
        end)
        if #carriedItems>0 then
            local insertIdx=#sections+1
            for i,sec in ipairs(sections) do
                if sec.header=="[Equipment]" then insertIdx=i+1; break end
            end
            table.insert(sections,insertIdx,{header="[Carried Items]",items=carriedItems})
        end
    end
    local equippedTool=nil; local equippedName=""
    for _,obj in ipairs(charModel:GetChildren()) do
        if obj.ClassName=="Tool" then
            equippedTool=obj
            pcall(function() equippedName=obj.Name end)
            break
        end
    end
    if equippedTool then
        local insertIdx=1
        for i,sec in ipairs(sections) do
            if sec.header=="[Equipment]" or sec.header=="[Carried Items]" then
                insertIdx=i+1
            end
        end
        table.insert(sections,insertIdx,{header="[Primary] "..equippedName,items=getWeaponData(equippedTool)})
    end
    return sections
end

local function buildLines(entityLabel,sections)
    local out={}
    out[#out+1]={text=entityLabel,color=Color3.fromRGB(80,220,255)}
    if #sections==0 then
        out[#out+1]={text="  (no data)",color=Color3.fromRGB(120,120,120)}
        return out
    end
    for _,sec in ipairs(sections) do
        out[#out+1]={text=sec.header,color=Color3.fromRGB(255,200,60)}
        for _,item in ipairs(sec.items) do
            local col
            if item.isAmmo then col=Color3.fromRGB(100,210,255)
            elseif item.isAttachment then col=Color3.fromRGB(180,180,255)
            else col=invItemColor(item.name) end
            out[#out+1]={text="  |- "..item.name,color=col}
        end
    end
    return out
end

