-- ============================================================
--  Infinite Stamina
--  getgc() is called ONCE off the main thread and cached.
--  applygc() is cheap and safe to call in the loop.
-- ============================================================
local STAMINA = {
    enabled  = false,
    loopId   = 0,
    drainCache = nil,
    regenCache = nil,
}

local STAMINA_DRAIN_PAYLOAD = {
    staminaDrainPerSecond=0, staminaDrain=0, drainRate=0,
    staminaCost=0, sprintDrain=0, exhaustionRate=0, staminaDecay=0,
}
local STAMINA_REGEN_PAYLOAD = {
    staminaRegen=999, regenRate=999, staminaRegenRate=999,
}

local function applyStaminaCached()
    -- applygc is cheap — only runs if cache already built
    if STAMINA.drainCache then
        pcall(applygc, STAMINA.drainCache, STAMINA_DRAIN_PAYLOAD)
    end
    if STAMINA.regenCache then
        pcall(applygc, STAMINA.regenCache, STAMINA_REGEN_PAYLOAD)
    end
end

local function startStamina()
    STAMINA.loopId = STAMINA.loopId + 1
    local myId = STAMINA.loopId

    -- Build GC cache ONCE off main thread so the game doesn't freeze
    task.spawn(function()
        task.wait(0.1)  -- tiny delay so the toggle UI can finish rendering
        pcall(function()
            STAMINA.drainCache = getgc({
                "staminaDrainPerSecond","staminaDrain","drainRate",
                "staminaCost","sprintDrain","exhaustionRate","staminaDecay",
            })
        end)
        pcall(function()
            STAMINA.regenCache = getgc({
                "staminaRegen","regenRate","staminaRegenRate",
            })
        end)

        -- Apply immediately after cache is built, then loop
        applyStaminaCached()

        while STAMINA.enabled and STAMINA.loopId == myId do
            task.wait(2)
            if not STAMINA.enabled or STAMINA.loopId ~= myId then break end
            applyStaminaCached()
        end
    end)
end

local function stopStamina()
    STAMINA.enabled    = false
    STAMINA.loopId     = STAMINA.loopId + 1
    STAMINA.drainCache = nil
    STAMINA.regenCache = nil
end

