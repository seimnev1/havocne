local function invItemColor(name)
    local tier=ITEM_TIER[name]
    if not tier then return Color3.fromRGB(200,200,200) end
    if tier=="mythic"     then return Color3.fromRGB(255,60,60)
    elseif tier=="rare"   then return Color3.fromRGB(180,60,255)
    elseif tier=="keys"   then return Color3.fromRGB(255,230,50)
    elseif tier=="usable" then return Color3.fromRGB(60,210,210)
    elseif tier=="cash"   then return Color3.fromRGB(100,255,100)
    elseif tier=="uncommon" then return Color3.fromRGB(80,200,80)
    else return Color3.fromRGB(200,200,200) end
end

local function cap(s)
    return (s:gsub("(%a)([%w_\']*)",function(a,b) return a:upper()..b end))
end

local function isWeapon(tool)
    local r=false
    pcall(function()
        local d=tool:FindFirstChild("_data")
        if d and d:FindFirstChild("ammoSize") then r=true end
    end)
    return r
end

local function getWeaponData(tool)
    local lines={}
    pcall(function()
        local dataF=tool:FindFirstChild("_data")
        if dataF then
            local cur=dataF:FindFirstChild("ammoCurrent")
            local siz=dataF:FindFirstChild("ammoSize")
            local mag=dataF:FindFirstChild("mag")
            local dur=dataF:FindFirstChild("durability")
            local maxDur=dataF:FindFirstChild("maxDurability")
            if cur and siz then
                lines[#lines+1]={name="Ammo: "..floor(cur.Value or 0).." / "..floor(siz.Value or 0),isAmmo=true}
            end
            if mag then lines[#lines+1]={name="Mags: "..floor(mag.Value or 0)} end
            if dur and maxDur and (maxDur.Value or 0)>0 then
                lines[#lines+1]={name="Condition: "..floor((dur.Value/maxDur.Value)*100).."%"}
            end
        end
        local atF=tool:FindFirstChild("_at")
        if atF then
            for _,att in ipairs(atF:GetChildren()) do
                if att:IsA("Model") then lines[#lines+1]={name=att.Name,isAttachment=true} end
            end
        end
    end)
    return lines
end

