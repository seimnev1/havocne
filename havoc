local OFF = {}
do
    local _raw = {}
    pcall(function()
        local res = game:HttpGet("https://offsets.imtheo.lol/Offsets.json")
        _raw = (HttpService:JSONDecode(res) or {}).Offsets or {}
    end)
    local function o(sec, key, fb)
        local s = _raw[sec]; return (s and s[key]) or fb
    end
    OFF.FOG_END      = o("Lighting",   "FogEnd",   0x13C)
    OFF.FOG_START    = o("Lighting",   "FogStart", 0x140)
    OFF.ATMO_DENSITY = o("Atmosphere", "Density",  0x0E8)
    OFF.ATMO_GLARE   = o("Atmosphere", "Glare",    0x0EC)
    OFF.ATMO_HAZE    = o("Atmosphere", "Haze",     0x0F0)
    OFF.ATMO_OFFSET  = o("Atmosphere", "Offset",   0x0F4)
end

-- ============================================================
--  No Fog
-- ============================================================
local FOG = {
    lightingAddr=0, atmoAddr=0,
    origEnd=100000, origStart=0,
    origDensity=0.3, origGlare=0, origHaze=0, origOffset=0.25,
    captured=false, enabled=false, last=false,
}

local function captureFog()
    FOG.captured = true
    pcall(function() FOG.lightingAddr = Lighting.Address or 0 end)
    pcall(function() FOG.origEnd = Lighting.FogEnd; FOG.origStart = Lighting.FogStart end)
    local atmo = Lighting:FindFirstChildOfClass("Atmosphere")
    if atmo then
        pcall(function() FOG.atmoAddr = atmo.Address or 0 end)
        pcall(function()
            FOG.origDensity = atmo.Density; FOG.origGlare  = atmo.Glare
            FOG.origHaze    = atmo.Haze;    FOG.origOffset = atmo.Offset
        end)
    end
end

local function applyNoFog()
    if not FOG.captured then captureFog() end
    if not memory_write then return end
    if FOG.lightingAddr ~= 0 then
        memory_write("float", FOG.lightingAddr + OFF.FOG_END,   9e8)
        memory_write("float", FOG.lightingAddr + OFF.FOG_START, 9e8)
    end
    if FOG.atmoAddr ~= 0 then
        memory_write("float", FOG.atmoAddr + OFF.ATMO_DENSITY, 0)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_GLARE,   0)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_HAZE,    0)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_OFFSET,  0)
    end
end

local function restoreFog()
    if not FOG.captured or not memory_write then return end
    if FOG.lightingAddr ~= 0 then
        memory_write("float", FOG.lightingAddr + OFF.FOG_END,   FOG.origEnd)
        memory_write("float", FOG.lightingAddr + OFF.FOG_START, FOG.origStart)
    end
    if FOG.atmoAddr ~= 0 then
        memory_write("float", FOG.atmoAddr + OFF.ATMO_DENSITY, FOG.origDensity)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_GLARE,   FOG.origGlare)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_HAZE,    FOG.origHaze)
        memory_write("float", FOG.atmoAddr + OFF.ATMO_OFFSET,  FOG.origOffset)
    end
end

-- Fog update loop (10hz)
local fogTimer = 0
HavocESP:Connect(RunService.Heartbeat, function(dt)
    fogTimer = fogTimer + dt
    if fogTimer < 0.1 then return end
    fogTimer = 0
    if FOG.enabled then
        applyNoFog()
    elseif FOG.last then
        restoreFog()
    end
    FOG.last = FOG.enabled
end)

