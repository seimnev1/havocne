local INSTANT_LOOT = { enabled=false }
local IL_GC_KEYS = {
    "search_speed","searchSpeed","SearchSpeed","searchTime","SearchTime",
    "searchDuration","lootSearchTime","containerSearchTime","level","required_level",
}
local IL_GC_VALUES = {
    search_speed=999999,searchSpeed=999999,SearchSpeed=999999,
    searchTime=0,SearchTime=0,searchDuration=0,
    lootSearchTime=0,containerSearchTime=0,level=50,required_level=0,
}
local IL_CACHE=nil
local function il_applyGC()
    pcall(function()
        if not IL_CACHE or #IL_CACHE==0 then IL_CACHE=getgc(IL_GC_KEYS) end
        if IL_CACHE and #IL_CACHE>0 then applygc(IL_CACHE,IL_GC_VALUES) end
    end)
end
local function il_patchSkillsOn(model)
    if not model then return end
    local pd=model:FindFirstChild("playerData")
    local sk=pd and pd:FindFirstChild("skills")
    if not sk then return end
    local sc=sk:FindFirstChild("Scavenger")
    local lv=sc and sc:FindFirstChild("level")
    if lv then pcall(function() lv.Value=50 end) end
end
local function il_patchLocal()
    local lp=Players.LocalPlayer; if not lp then return end
    local ch=lp.Character; il_patchSkillsOn(ch)
    if ch then
        local ok,rf=pcall(function() return ch.Parent end)
        if ok and rf and rf~=workspace then il_patchSkillsOn(rf:FindFirstChild(lp.Name)) end
    end
end
local function startInstantLoot()
    IL_CACHE=nil; il_applyGC(); il_patchLocal()
    task.spawn(function()
        while INSTANT_LOOT.enabled do
            task.wait(2); if not INSTANT_LOOT.enabled then break end
            il_applyGC(); il_patchLocal()
        end
    end)
end

