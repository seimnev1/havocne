local _entMap = {}
local _entDeadTime = {}  -- id -> tick() when it went inactive
local ENT_GRACE = 2      -- seconds to keep dead entries before removing

local function rebuildEntities()
    local lp=Players.LocalPlayer; local char=lp and lp.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end  -- don't clear â€” keep showing last known state

    local myPos=hrp.Position
    local maxDSq=CFG.entityMaxDist*CFG.entityMaxDist

    local pCharSet={}; local pNameSet={}
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr.Character then pCharSet[plr.Character]=true end
        pNameSet[plr.Name]=true
    end
    if char then pCharSet[char]=true end

    -- Track which IDs are active this frame
    local activeIds={}

    -- Players
    if CFG.showPlayers then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=lp then
                local ok,pc=pcall(function() return plr.Character end)
                if ok and pc then
                    local ok2,ph=pcall(function() return pc:FindFirstChild("HumanoidRootPart") end)
                    if ok2 and ph and ph.Parent then
                        local rp=ph.Position
                        local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                        local dSq=dx*dx+dy*dy+dz*dz
                        if dSq<=maxDSq then
                            local id="plr_"..plr.UserId
                            activeIds[id]=true
                            -- Update existing entry in-place or create new one
                            local e=_entMap[id]
                            if not e then
                                local ok3,hum=pcall(function() return pc:FindFirstChildOfClass("Humanoid") end)
                                e={hrp=ph,char=pc,label=plr.Name,plr=plr,
                                   hum=ok3 and hum or nil,isPlayer=true,
                                   color=selectedColor(CFG.playerColor),_distSq=dSq}
                                _entMap[id]=e
                            else
                                -- Only update refs, never nil them out
                                e.hrp=ph; e.char=pc; e._distSq=dSq; e.color=selectedColor(CFG.playerColor)
                                if not e.hum or not e.hum.Parent then
                                    local ok3,hum=pcall(function() return pc:FindFirstChildOfClass("Humanoid") end)
                                    if ok3 then e.hum=hum end
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    -- NPCs: scan every folder/model in workspace directly
    -- All NPCs sit one level deep inside a randomly-named folder
    if CFG.showNPCs then
        -- helper: register a model as an NPC if it has a Humanoid
        local function tryRegisterNPC(child)
            if child.ClassName=="Model" and not pCharSet[child] and not pNameSet[child.Name] and child~=char then
                local hum=child:FindFirstChildOfClass("Humanoid")
                if hum then
                    local ph=child:FindFirstChild("HumanoidRootPart") or child:FindFirstChild("Torso")
                    if ph and ph.Parent then
                        local rp=ph.Position
                        local dx=rp.X-myPos.X; local dy=rp.Y-myPos.Y; local dz=rp.Z-myPos.Z
                        local dSq=dx*dx+dy*dy+dz*dz
                        if dSq<=maxDSq then
                            local id="npc_"..tostring(child)
                            activeIds[id]=true
                            local e=_entMap[id]
                            if not e then
                                _entMap[id]={hrp=ph,char=child,label=child.Name,plr=nil,
                                    hum=hum,isPlayer=false,
                                    color=selectedColor(CFG.npcColor),_distSq=dSq}
                            else
                                e.hrp=ph; e.char=child; e._distSq=dSq; e.color=selectedColor(CFG.npcColor)
                                if not e.hum or not e.hum.Parent then e.hum=hum end
                            end
                        end
                    end
                end
            end
        end

        -- Scan workspace top-level containers (1 level deep)
        local ok,wsKids=pcall(function() return workspace:GetChildren() end)
        if ok and wsKids then
            for _,container in ipairs(wsKids) do
                if not pCharSet[container] and container~=char then
                    local cn=container.ClassName
                    if cn=="Folder" or cn=="Model" then
                        local ok2,kids=pcall(function() return container:GetChildren() end)
                        if ok2 and kids then
                            for _,child in ipairs(kids) do
                                tryRegisterNPC(child)
                            end
                        end
                    end
                end
            end
        end

        -- Also scan workspace.Buildings.Loots.Objects (boss/special NPCs live here)
        local ok2,objFolder=pcall(function()
            return workspace.Buildings.Loots.Objects
        end)
        if ok2 and objFolder then
            local ok3,kids=pcall(function() return objFolder:GetChildren() end)
            if ok3 and kids then
                for _,child in ipairs(kids) do
                    tryRegisterNPC(child)
                end
            end
        end
    end

    -- Remove entries that are no longer active
    local now = tick()
    for id in pairs(_entMap) do
        if not activeIds[id] then
            if not _entDeadTime[id] then
                _entDeadTime[id] = now
            elseif now - _entDeadTime[id] > ENT_GRACE then
                _entMap[id] = nil
                _entDeadTime[id] = nil
            end
        else
            _entDeadTime[id] = nil  -- reset death timer if active again
        end
    end

    -- Rebuild flat sorted list from map
    local out={}
    for _,e in pairs(_entMap) do out[#out+1]=e end
    table.sort(out,function(a,b) return a._distSq<b._distSq end)
    for i=ENT_MAX+1,#out do out[i]=nil end
    entObjects=out
end

